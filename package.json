{
  "name": "critterboard",
  "version": "1.4.0",
  "private": true,
  "description": "Critterboard — offline insect ID with sass. React Native + TypeScript port of the handoff prototype.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval": "evalite",
    "eval:watch": "evalite --watch",
    "build:dev": "npx eas-cli build --profile development",
    "build:preview": "npx eas-cli build --profile preview",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "build:android": "npx eas-cli build --platform android --profile production",
    "build:all": "npx eas-cli build --platform all --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production",
    "submit:android": "npx eas-cli submit --platform android --profile production"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.79",
    "@expo/metro-runtime": "~4.0.1",
    "@presidio-dev/hai-guardrails": "^1.12.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@sentry/react-native": "~6.3.0",
    "ai": "^6.0.190",
    "expo": "~56.0.3",
    "expo-asset": "~56.0.17",
    "expo-camera": "~16.0.18",
    "expo-file-system": "~19.0.0",
    "expo-gl": "~56.0.5",
    "expo-haptics": "~14.0.1",
    "expo-image-picker": "~16.0.6",
    "expo-location": "~18.0.10",
    "expo-modules-core": "^56.0.14",
    "expo-notifications": "~0.29.14",
    "expo-sharing": "~13.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~56.0.19",
    "llama.rn": "^0.9.0",
    "react": "18.3.1",
    "react-cartoon-planet": "^1.1.2",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-executorch": "^0.9.0",
    "react-native-executorch-expo-resource-fetcher": "^0.9.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "three": "^0.184.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-class-static-block": "^7.29.7",
    "@types/react": "~18.3.12",
    "@types/three": "^0.184.1",
    "autoevals": "^0.0.132",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~12.0.0",
    "eas-cli": "^20.3.0",
    "evalite": "^0.19.0",
    "typescript": "~5.7.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
