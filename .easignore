# EAS uses this INSTEAD of .gitignore for the build upload, so it must be
# self-contained. Goal: ship only what the React Native bundle needs.

# --- standard ignores (mirror .gitignore) ---
node_modules/
.expo/
dist/
web-build/
.vscode/
.idea/
.claude/
.DS_Store
.env*
!.env.example
*.tsbuildinfo
__pycache__/
*.pyc
.venv/
venv/
*.tmp*

# Native dirs are regenerated by EAS prebuild
/ios/
/android/

# --- not part of the app bundle ---
training/
evals/
website/
worker/
tools/
docs/
tasks/
packs/
netlify.toml

# --- store credentials: never upload as plain files ---
google-service-account.json
*.p8
*.p12
*.mobileprovision
*.keystore
