EXPO_PUBLIC_SENTRY_DSN=
# Cloudflare Workers backend. Setting this auto-activates the remote adapter.
# Deploy worker/ first: cd worker && npm install && wrangler deploy
EXPO_PUBLIC_BACKEND_URL=
# Temporary cloud chat proof-of-concept (AI SDK + Gemini).
GEMINI_API_KEY=
# Expo client fallback for this POC (client-side key exposure; do not use in production).
EXPO_PUBLIC_GEMINI_API_KEY=
# Presidio guard-rails service. Start locally with: cd presidio-service && docker compose up
# When set, the app uses Presidio for richer NLP-backed PII detection in chat and display names.
# The service fails open — if unreachable, regex-based guardrails remain active.
EXPO_PUBLIC_PRESIDIO_URL=
